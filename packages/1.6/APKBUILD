# Asterisk 1.6.x (EOL ~2012) on Alpine 3.24 / OpenSSL 3 - FULLY FUNCTIONAL.
# Same fix family as 1.8 (editline configure, OpenSSL 3 methods, __P/bison,
# AST_INLINE_API, musl) plus: bundled AES .c files stubbed (HAVE_CRYPTO dead
# code), GLOB_NOMAGIC/GLOB_BRACE in compat.h, res_close() stub, and the two
# fixes that make loadable modules work on musl: a recursive-mutex static
# initializer (musl lacks PTHREAD_RECURSIVE_MUTEX_INITIALIZER_NP; without it
# the loader deadlocks when ast_module_register re-locks module_list during
# dlopen's constructor phase) and replacing the "while(!dlclose(lib))" probe-
# unload loops with a single dlclose (musl spins there). Result: 168 modules
# load, chan_sip answers, daemon reaches ready.
#
# TDS OMITTED (r1, 2026-07-22): built with --without-tds, so no cdr_tds /
# cel_tds and no asterisk-tds subpackage. The modules built fine, but
# apk-tools 3 cannot select "asterisk-tds=1.6.2.24-r0" at all - it aborts with
# "asterisk-tds-22.9.0-r0: breaks world[asterisk-tds=1.6.2.24-r0@...]" no matter
# how the install is pinned (@tag, =version, --repository, seeding world,
# disabling Alpine's main, pre-installing freetds all fail identically). It is
# an apk3 solver limitation, not a packaging fault, and it is specific to this
# one package at this one version: asterisk-tds resolves normally at 1.8.32.3,
# 16.30.1 and 20.20.1, and every other 1.6.2.24 subpackage installs fine.
# Rather than keep shipping a package nobody can install, the modules are no
# longer built. They only wrote CDR/CEL rows to MSSQL/Sybase and are not in the
# call path; deployments needing that can use asterisk-odbc (which installs
# fine here) with a FreeTDS ODBC driver.
# Maintainer: Andrius Kairiukstis <k@c0.lt>
pkgname=asterisk
pkgver=1.6.2.24
pkgrel=1
pkgdesc="Modular Open Source PBX System (1.6, EOL)"
pkgusers="asterisk"
pkggroups="asterisk"
url="https://www.asterisk.org/"
arch="all"
license="GPL-2.0-only"
options="!check !strip"
depends_dev="$pkgname=$pkgver-r$pkgrel"
makedepends="
	autoconf
	automake
	alsa-lib-dev
	bison
	bsd-compat-headers
	curl-dev
	findutils
	flex
	jansson-dev
	linux-headers
	libedit-dev
	libpq-dev
	libtool
	libxml2-dev
	lua-dev
	ncurses-dev
	newt-dev
	openssl-dev
	popt-dev
	spandsp-dev
	speexdsp-dev
	sqlite-dev
	tar
	tiff-dev
	unixodbc-dev
	util-linux-dev
	zlib-dev
	"
# NOTE: dahdi-tools-dev, libpri-dev, libresample removed from aports (3.24).
install="$pkgname.pre-install $pkgname.pre-upgrade"
subpackages="
	$pkgname-dev
	$pkgname-doc
	$pkgname-odbc
	$pkgname-fax
	$pkgname-sample-config:config:noarch
	$pkgname-sounds-moh:sound_moh:noarch
	$pkgname-sounds-en:sound_en:noarch
	$pkgname-openrc
	"
_download="https://downloads.asterisk.org/pub/telephony/asterisk/releases"
source="$_download/asterisk-$pkgver.tar.gz
	asterisk.initd
	asterisk.confd
	asterisk.logrotate
	"
builddir="$srcdir/asterisk-$pkgver"

prepare() {
	default_prepare

	# 1.6's ancient config.sub/config.guess don't recognize alpine-linux-musl.
	# Replace with the system's modern versions.
	cp /usr/share/abuild/config.sub /usr/share/abuild/config.guess . 2>/dev/null \
		|| cp /usr/share/misc/config.sub /usr/share/misc/config.guess . 2>/dev/null \
		|| true

	# ast_expr2 forward-declares op_* via the __P() K&R macro. The shipped
	# pre-generated .c/.y files use __P which expands wrong on modern gcc
	# (implicit int() decls conflict with real struct val * returns). Replace
	# __P((args)) with (args) in BOTH the .y and the shipped .c/.fl files so
	# the declarations are plain prototypes. Do NOT regenerate from .y/.fl - 
	# modern bison/flex produce incompatible output for 1.8's old grammars.
	sed -i 's/__P((\([^)]*\)))/(\1)/g' main/ast_expr2.y main/ast_expr2.c main/ast_expr2.fl main/ast_expr2f.c
	# musl's glob() lacks GLOB_NOMAGIC and GLOB_BRACE (glibc extensions) used
	# in res/ael/ael.flex, the pre-generated ael_lex.c, and include/asterisk/compat.h
	# (MY_GLOB_FLAGS macro used by config.c). Replace with 0 (no-op flags).
	sed -i 's/GLOB_NOMAGIC/0/g; s/GLOB_BRACE/0/g' \
		res/ael/ael.flex res/ael/ael_lex.c include/asterisk/compat.h 2>/dev/null || true

	# OpenSSL 3 removed SSLv2/v3/SSLv23/TLSv1 method constructors. Replace
	# them with the modern generic TLS_client_method()/TLS_server_method().
	sed -i \
		-e 's/SSLv2_client_method()/TLS_client_method()/g' \
		-e 's/SSLv3_client_method()/TLS_client_method()/g' \
		-e 's/SSLv23_client_method()/TLS_client_method()/g' \
		-e 's/TLSv1_client_method()/TLS_client_method()/g' \
		-e 's/SSLv2_server_method()/TLS_server_method()/g' \
		-e 's/SSLv3_server_method()/TLS_server_method()/g' \
		-e 's/SSLv23_server_method()/TLS_server_method()/g' \
		-e 's/TLSv1_server_method()/TLS_server_method()/g' \
		main/tcptls.c
	# OpenSSL 3 made SSL an opaque type - replace direct struct field access
	# (ssl->server) with SSL_is_server(), and ERR_remove_state (removed) with
	# ERR_clear_error().
	sed -i \
		-e 's/!stream->ssl->server/!SSL_is_server(stream->ssl)/g' \
		-e 's/ERR_remove_state(0)/ERR_clear_error()/g' \
		main/tcptls.c
	# 1.8 ships a static gethostbyname_r that conflicts with musl's declaration.
	# Rename it internally to avoid the static/non-static clash.
	sed -i 's/gethostbyname_r/__ast_gethostbyname_r/g' main/utils.c
	# musl's resolver doesn't expose res_close() (glibc extension). dns.c calls
	# it after a DNS lookup to reset resolver state; musl doesn't need it.
	# Stub the call to a no-op.
	sed -i 's/res_close();/\/* res_close() - not in musl *\//' main/dns.c
	# AST_INLINE_API has 4 variants under #ifdefs. The default (line 49) is
	# "hdr; extern inline hdr body" - old GNU89 extern-inline semantics that
	# modern gcc (C99) treats differently, emitting definitions in every TU
	# → multiple-definition link errors. Replace ALL variants with plain
	# "static inline hdr body" so each TU gets its own static copy.
	sed -i 's|#define AST_INLINE_API(hdr, body).*|#define AST_INLINE_API(hdr, body) static inline hdr body|g' include/asterisk/inline_api.h

	# lua header path fix (1.8 expects lua5.1/ prefix)
	sed -i -e 's:lua5.1/::' pbx/pbx_lua.c
	# disable iconv (musl)
	sed -i -e 's/PBX_ICONV=1/PBX_ICONV=0/g' configure.ac

	# 1.8's bundled editline uses autoconf 2.13 whose "compiler works" link
	# test fails under modern hardening CFLAGS/LDFLAGS (the test main(){return 0;}
	# links with the full _ASTCFLAGS captured by the main configure). Patch the
	# editline configure to assume the compiler works rather than run the test.
	sed -i 's/ac_cv_prog_cc_works=no/ac_cv_prog_cc_works=yes/g' main/editline/configure

	# Bundled AES (aescrypt.c/aeskey.c/aestab.c) is dead code: HAVE_CRYPTO is
	# defined (system OpenSSL provides AES) and the sources guard their entire
	# bodies with #ifndef HAVE_CRYPTO. But aestab.c does not include autoconfig.h,
	# so HAVE_CRYPTO is invisible to that translation unit and GCC 15 trips on
	# the bundled tables (byte-order #error, non-constant initializers). Stub the
	# .c files to empty - the objects link as no-ops; libcrypto provides AES.
	: > main/aescrypt.c
	: > main/aeskey.c
	: > main/aestab.c

	# Asterisk REQUIRES recursive mutexes (see include/asterisk/lock.h).
	# musl lacks the glibc-specific PTHREAD_RECURSIVE_MUTEX_INITIALIZER_NP, so
	# configure leaves statically-initialized mutexes as NORMAL. The module
	# loader then deadlocks: load_modules holds the module_list mutex across
	# dlopen, and the module constructor's ast_module_register() re-locks it.
	# musl encodes the mutex type in the first int of pthread_mutex_t
	# (PTHREAD_MUTEX_RECURSIVE == 1); provide a static recursive initializer.
	sed -i 's|#define PTHREAD_MUTEX_INIT_VALUE[[:space:]]*PTHREAD_MUTEX_INITIALIZER|#define PTHREAD_MUTEX_INIT_VALUE { { PTHREAD_MUTEX_RECURSIVE } }|' include/asterisk/lock.h

	# load_dynamic_module probes each module with a quiet dlopen, then unloads
	# via "while (!dlclose(lib));" to fully release a refcounted handle. On musl
	# this loops indefinitely (dlclose on the probe handle never terminates the
	# loop). Replace the loops with a single dlclose call.
	sed -i 's/while (!dlclose(lib));/dlclose(lib);/' main/loader.c

	# 1.6 needs autotools re-run (bootstrap.sh)
	./bootstrap.sh
}

build() {
	cd "$builddir"
	# 1.6's ancient editline sub-configure (autoconf 2.13) link test fails with
	# ANY -Wl flag ("C compiler cannot create executables"). Build with empty
	# LDFLAGS - the hardening flags aren't critical for an EOL 1.6 package.
	export LDFLAGS=""
	SHA1SUM="$PWD"/build_tools/sha1sum-sh ./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--libdir=/usr/lib \
		--localstatedir=/var \
		--disable-xmldoc \
		--with-gsm=internal \
		--without-iconv \
		--with-popt \
		--with-z \
		--with-newt \
		--with-odbc \
		--with-postgres \
		--without-tds \
		--without-dahdi \
		--without-pri \
		--without-tonezone \
		--with-sqlite3 \
		--with-asound \
		--without-x11 \
		--with-spandsp \
		--with-ssl \
		CFLAGS="$CFLAGS -fcommon"

	rm -f menuselect.makeopts
	# NOTE: do NOT delete the pre-generated ast_expr2.c / ael_lex.c - modern
	# bison/flex (Alpine 3.24) produce incompatible output for 1.6's old
	# grammars. Patch the shipped .c/.fl files directly instead (see prepare).
	make menuselect.makeopts
	# musl dlopen: modules can't resolve the core binary's symbols unless the
	# binary is linked with --export-dynamic. Unlike 1.8 (which has an
	# unconditional --version-script,asterisk.exports line), 1.6 only adds
	# --export-dynamic inside a LOADABLE_MODULES conditional that isn't
	# reliably set. Append it unconditionally right before the link rule.
	sed -i '/^$(MAIN_TGT):/i ASTLINK += -Wl,--export-dynamic' main/Makefile
	make ASTCFLAGS="$CFLAGS -fcommon"
}


package() {
	cd "$builddir"
	make -j1 DESTDIR="$pkgdir" install

	install -d "$pkgdir"/var/run/asterisk
	install -m755 -D "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -m644 -D "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
	install -m644 -D "$srcdir"/$pkgname.logrotate \
		"$pkgdir"/etc/logrotate.d/$pkgname

	chown -R asterisk:asterisk "$pkgdir"/var/*/asterisk
	chown -R asterisk:asterisk "$pkgdir"/etc/asterisk
}

odbc() { amove usr/lib/asterisk/modules/*odbc*; }
fax() { amove usr/lib/asterisk/modules/*_fax*; }

config() {
	pkgdesc="Sample configuration files for asterisk"
	cd "$builddir"
	mkdir -p "$subpkgdir"/var/lib/asterisk/phoneprov
	make -j1 samples DESTDIR="$subpkgdir"
	chown -R asterisk:asterisk "$subpkgdir"/var/*/asterisk
	chown -R asterisk:asterisk "$subpkgdir"/etc/asterisk
}

sound_moh() {
	pkgdesc="Default on-hold music files for asterisk"
	depends=
	amove var/lib/asterisk/moh
	chown -R asterisk:asterisk "$subpkgdir"/var/lib/asterisk
}

sound_en() {
	pkgdesc="English sound files for asterisk"
	depends=
	amove var/lib/asterisk/sounds/en
	chown -R asterisk:asterisk "$subpkgdir"/var/lib/asterisk
}
