# Asterisk Certified 22.8-cert3 — latest certified LTS, on Alpine 3.24 / OpenSSL 3.
# Certified Asterisk is built from the same 22.x tree with extra QA; the source
# tarball is asterisk-certified-<ver>.tar.gz and extracts to a "certified/" dir.
#
# pkgver note: apk versioning has no "cert" suffix, so we encode cert3 of the
# 22.8.0 base as 22.8.0.3 (a 4th numeric component). The real upstream label is
# "22.8-cert3"; the description and the source tarball name carry that.
# Maintainer: Andrius Kairiukstis <k@c0.lt>
pkgname=asterisk
pkgver=22.8.0.3
pkgrel=0
pkgdesc="Modular Open Source PBX System (Certified Asterisk 22.8-cert3)"
pkgusers="asterisk"
pkggroups="asterisk"
url="https://www.asterisk.org/"
arch="all"
license="GPL-2.0-only WITH Asterisk-linking-protocols-exception"
options="!check"  # Test suite is separate, requires separate build
depends_dev="$pkgname=$pkgver-r$pkgrel"
makedepends="
	alsa-lib-dev
	bluez-dev
	bsd-compat-headers
	curl-dev
	findutils
	freetds-dev
	imap-dev
	jansson-dev
	libcap-dev
	libedit-dev
	libogg-dev
	libresample
	libsrtp-dev
	libtool
	libxml2-dev
	lua-dev
	ncurses-dev
	newt-dev
	openssl-dev>3
	opus-dev
	opusfile-dev
	pjproject-dev
	popt-dev
	libpq-dev
	spandsp-dev
	speexdsp-dev
	speex-dev
	sqlite-dev
	openldap-dev
	tar
	tiff-dev
	unbound-dev
	unixodbc-dev
	util-linux-dev
	zlib-dev
	"
install="$pkgname.pre-install $pkgname.pre-upgrade"
subpackages="
	$pkgname-dbg
	$pkgname-dev
	$pkgname-doc
	$pkgname-odbc
	$pkgname-fax
	$pkgname-sample-config:config:noarch
	$pkgname-sounds-moh:sound_moh:noarch
	$pkgname-sounds-en:sound_en:noarch
	$pkgname-mobile
	$pkgname-curl:_curl
	$pkgname-srtp
	$pkgname-speex
	$pkgname-opus
	$pkgname-openrc
	"
# NOTE: subpackages omitted because certified 22.8 doesn't build them on
# Alpine 3.24 (verified by inspecting the [LD] module output):
#  - pgsql : libpq 18 dropped pg_encoding_to_char (configure check fails)
#  - ldap  : res_config_ldap not selected at menuselect despite openldap-dev
#  - tds   : FreeTDS modules don't build
#  - prometheus : 20.x+-only feature
# Newer Asterisk (22.10+/23+) builds all of these fine on the same base.
# (Alpine 3.24): the pgsql configure check fails and the ldap module doesn't
# build, so those splits would be empty. Newer Asterisk (22.10+/23+) is fine.
# `pg_encoding_to_char within Postgres headers` fails against libpq 18
# (Alpine 3.24), so no *_pgsql modules are built and the split would be
# empty. Newer Asterisk (22.10+/23+) handles libpq 18 fine.
# Open-source Opus codec from https://github.com/traud/asterisk-opus/commits/asterisk-13.7
_opus_commit=a959f072d3f364be983dd27e6e250b038aaef747
_cert_download="https://downloads.asterisk.org/pub/telephony/certified-asterisk/releases"
source="asterisk-certified-22.8-cert3.tar.gz::$_cert_download/asterisk-certified-22.8-cert3.tar.gz
	https://dev.alpinelinux.org/~tteras/asterisk-addon-mp3-r201.patch.gz
	asterisk-13.7-$_opus_commit.tar.gz::https://github.com/traud/asterisk-opus/archive/$_opus_commit.tar.gz
	10-musl-mutex-init.patch
	20-musl-astmm-fix.patch
	40-asterisk-cdefs.patch
	41-asterisk-ALLPERMS.patch
	gethostbyname_r.patch
	asterisk.initd
	asterisk.confd
	asterisk.logrotate
	"
# Certified tarball extracts to asterisk-certified-<ver>/
builddir="$srcdir/asterisk-certified-22.8-cert3"

# secfixes (certified 22.8 line):
#   22.8-cert3-r0:
#     - latest certified point release

prepare() {
	default_prepare

	sed -i -e 's/ASTSSL_LIBS:=$(OPENSSL_LIB)/ASTSSL_LIBS:=-Wl,--no-as-needed $(OPENSSL_LIB) -Wl,--as-needed/g' main/Makefile

	cp --verbose ../asterisk-opus*/codecs/* codecs
}

build() {
	SHA1SUM="$PWD"/build_tools/sha1sum-sh ./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--libdir=/usr/lib \
		--localstatedir=/var \
		--disable-xmldoc \
		--enable-permanent-dlopen \
		--with-gsm=internal \
		--with-popt \
		--with-z \
		--with-newt \
		--with-unixodbc \
		--with-postgres \
		--with-tds \
		--with-resample \
		--with-ldap \
		--with-sqlite3 \
		--with-speex \
		--with-asound \
		--without-dahdi \
		--without-pri \
		--without-tonezone \
		--without-x11 \
		--without-pjproject-bundled \
		--with-spandsp \
		--with-bluetooth \
		--with-libcurl \
		--with-libedit \
		--with-srtp \
		--with-imap=system \
		--with-opus \
		--with-opusfile \
		--with-prometheus \
		CFLAGS="$CFLAGS -DENABLE_SRTP_AES_256"

	rm -f menuselect.makeopts
	make menuselect.makeopts

	# Certified 22.8 = same 22.x tree: chan_sip removed, PJSIP only.
	# HEP modules (extended support) are excluded from certified's default
	# menuselect set — enable them explicitly so res_hep*/Homer capture ships.
	./menuselect/menuselect \
		--enable app_voicemail_imap \
		--enable chan_mobile \
		--disable BUILD_NATIVE \
		--enable codec_opus_open_source \
		--enable chan_console \
		--enable chan_pjsip \
		--enable res_hep \
		--enable res_hep_pjsip \
		--enable res_hep_rtcp \
		menuselect.makeopts

	make LDCONFIG=
}

package() {
	make install \
		DESTDIR="$pkgdir" \
		LDCONFIG_FLAGS="-n" \
		ASTVARLIBDIR=/usr/share/asterisk \
		ASTDATADIR=/usr/share/asterisk

	make DESTDIR="$pkgdir" install-headers

	install -d "$pkgdir"/var/run/asterisk

	install -m755 -D "$srcdir"/$pkgname.initd "$pkgdir"/etc/init.d/$pkgname
	install -m644 -D "$srcdir"/$pkgname.confd "$pkgdir"/etc/conf.d/$pkgname
	install -m644 -D "$srcdir"/$pkgname.logrotate \
		"$pkgdir"/etc/logrotate.d/$pkgname

	chown -R asterisk:asterisk "$pkgdir"/var/*/asterisk
	chown -R asterisk:asterisk "$pkgdir"/etc/asterisk
	chmod -R u=rwX,g=rX,o= "$pkgdir"/etc/asterisk
}

odbc() { amove usr/lib/asterisk/modules/*_odbc*; }
fax() { amove usr/lib/asterisk/modules/*_fax*; }
mobile() { amove usr/lib/asterisk/modules/*_mobile*; }
_curl() { amove usr/lib/asterisk/modules/*_curl*; }
srtp() { amove usr/lib/asterisk/modules/*_srtp*; }
speex() { amove usr/lib/asterisk/modules/*_speex*; }
opus() { amove usr/lib/asterisk/modules/codec_opus_open_source.so; }

config() {
	pkgdesc="Sample configuration files for asterisk"
	cd "$builddir"
	mkdir -p "$subpkgdir"/var/lib/asterisk/phoneprov
	make -j1 samples DESTDIR="$subpkgdir"

	chown -R asterisk:asterisk "$subpkgdir"/var/*/asterisk
	chown -R asterisk:asterisk "$subpkgdir"/etc/asterisk
	chmod -R u=rwX,g=rX,o= "$subpkgdir"/etc/asterisk
}

sound_moh() {
	pkgdesc="Default on-hold music files for asterisk"
	depends=
	amove usr/share/asterisk/moh
	chown -R asterisk:asterisk "$subpkgdir"/usr/share/asterisk
}

sound_en() {
	pkgdesc="English sound files for asterisk"
	depends=
	amove usr/share/asterisk/sounds/en
	chown -R asterisk:asterisk "$subpkgdir"/usr/share/asterisk
}
