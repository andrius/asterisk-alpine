# Environment Configuration for Asterisk Alpine Buildchain
# Copy this file to .env and customize as needed

# Repository Configuration
ALPINE_VERSION=v3.22
ARCH=x86_64
REPO_NAME=asterisk-alpine

# Key Configuration
KEY_NAME=packages@asterisk-alpine.rsa
MAINTAINER="Your Name <your.email@example.com>"

# Build Configuration
PACKAGER_PRIVKEY=/home/builder/.abuild/packages@asterisk-alpine.rsa
REPODEST=/home/builder/packages

# Optional: Custom mirror for faster downloads
# ALPINE_MIRROR=http://dl-cdn.alpinelinux.org/alpine

# Optional: Parallel build jobs (auto-detect by default)
# JOBS=4

# Optional: Enable ccache for faster rebuilds
# USE_CCACHE=true
